            "linux": {
                "command": "cmake",
                "args": [
                    "-S",
                    ".",
                    "-B",
                    "build/release",
                    "-G",
                    "Unix Makefiles",
                    "-DCMAKE_BUILD_TYPE=Release",
                    "-DCMAKE_CXX_COMPILER=g++"
                ],
                "options": {
                    "cwd": "${workspaceFolder}"
                }
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build/release"
            ],
            "windows": {
                "command": "C:/msys64/ucrt64/bin/cmake.exe",
                "args": [
                    "--build",
                    "build/release"
                ],
                "options": {
                    "cwd": "${workspaceFolder}",
                    "env": {
                        "PATH": "C:/msys64/ucrt64/bin;C:/msys64/usr/bin;${env:PATH}"
                    }
                }
            },
            "linux": {
                "command": "cmake",
                "args": [
                    "--build",
                    "build/release"
                ],
                "options": {
