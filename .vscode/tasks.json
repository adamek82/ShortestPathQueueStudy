            "dependsOn": "Configure Release",
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Run Debug",
            "type": "shell",
            "command": "${workspaceFolder}/build/debug/CppCMakeVSCodeTemplate",
            "args": [],
            "windows": {
                "command": "${workspaceFolder}/build/debug/CppCMakeVSCodeTemplate.exe",
                "args": [],
                "options": {
                    "cwd": "${workspaceFolder}",
                    "env": {
                        "PATH": "C:/msys64/ucrt64/bin;C:/msys64/usr/bin;${env:PATH}"
                    }
                }
            },
            "linux": {
                "command": "${workspaceFolder}/build/debug/CppCMakeVSCodeTemplate",
                "args": [],
                "options": {
                    "cwd": "${workspaceFolder}"
                }
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "Build Debug",
            "problemMatcher": []
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build/debug",
                "--target",
                "clean"
            ],
            "windows": {
                "command": "C:/msys64/ucrt64/bin/cmake.exe",
                "args": [
                    "--build",
                    "build/debug",
                    "--target",
                    "clean"
                ],
                "options": {
                    "cwd": "${workspaceFolder}",
                    "env": {
                        "PATH": "C:/msys64/ucrt64/bin;C:/msys64/usr/bin;${env:PATH}"
                    }
                }
            },
            "linux": {
                "command": "cmake",
                "args": [
                    "--build",
                    "build/debug",
                    "--target",
                    "clean"
                ],
                "options": {
                    "cwd": "${workspaceFolder}"
                }
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ]
}
