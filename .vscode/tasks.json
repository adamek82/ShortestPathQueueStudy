{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure Debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build/debug",
                "-G",
                "Unix Makefiles",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_CXX_COMPILER=g++"
            ],
            "windows": {
                "command": "C:/msys64/ucrt64/bin/cmake.exe",
                "args": [
                    "-S",
                    ".",
                    "-B",
                    "build/debug",
                    "-G",
                    "MinGW Makefiles",
                    "-DCMAKE_BUILD_TYPE=Debug",
                    "-DCMAKE_CXX_COMPILER=C:/msys64/ucrt64/bin/g++.exe"
                ],
                "options": {
                    "cwd": "${workspaceFolder}",
                    "env": {
                        "PATH": "C:/msys64/ucrt64/bin;C:/msys64/usr/bin;${env:PATH}"
                    }
                }
            },
            "linux": {
                "command": "cmake",
                "args": [
                    "-S",
                    ".",
                    "-B",
                    "build/debug",
                    "-G",
                    "Unix Makefiles",
                    "-DCMAKE_BUILD_TYPE=Debug",
                    "-DCMAKE_CXX_COMPILER=g++"
                ],
                "options": {
                    "cwd": "${workspaceFolder}"
                }
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build/debug"
            ],
            "windows": {
                "command": "C:/msys64/ucrt64/bin/cmake.exe",
                "args": [
                    "--build",
                    "build/debug"
                ],
                "options": {
                    "cwd": "${workspaceFolder}",
                    "env": {
                        "PATH": "C:/msys64/ucrt64/bin;C:/msys64/usr/bin;${env:PATH}"
                    }
                }
            },
            "linux": {
                "command": "cmake",
                "args": [
                    "--build",
                    "build/debug"
                ],
                "options": {
                    "cwd": "${workspaceFolder}"
                }
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "Configure Debug",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
