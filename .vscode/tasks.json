                    "-S",
                    ".",
                    "-B",
                    "build/release",
                    "-G",
                    "MinGW Makefiles",
                    "-DCMAKE_BUILD_TYPE=Release",
                    "-DCMAKE_CXX_COMPILER=C:/msys64/ucrt64/bin/g++.exe"
